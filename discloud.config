# Discloud config for automatic deploy
# See: https://docs.discloud.com/en/discloud.config
ID=
NAME=shift-management-bot
MAIN=index.js
NODE_VERSION=20
INSTALL=npm install
START=npm run deploy && npm start
# Comma-separated env var names that you'll configure in Discloud dashboard
ENV=DISCORD_TOKEN,CLIENT_ID,GUILD_ID

# If Discloud supports mounting a storage path, point it to `data` so shifts.json persists
# STORAGE=data
